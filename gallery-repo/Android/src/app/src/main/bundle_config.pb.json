// Bundle config for the Google AI Edge Gallery app.
// See: https://developer.android.com/studio/build/building-cmdline#bundleconfig
{
  "optimizations": {
    "uncompress_native_libraries": {
      "enabled": false
    },
    "splitsConfig": {
      "splitDimension": [
        {
          "value": "ABI"
        },
        {
          "value": "SCREEN_DENSITY"
        },
        {
          "value": "LANGUAGE"
        },
        {
          "value": "DEVICE_GROUP",
          "suffix_stripping": {
            "enabled": true,
            "default_suffix": "other"
          }
        }
      ]
    }
  }
}